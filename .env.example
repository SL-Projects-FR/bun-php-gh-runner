# GitHub organization or repository URL
GITHUB_URL=https://github.com/your-org

# Runner registration tokens (from GitHub Settings > Actions > Runners > New self-hosted runner)
RUNNER_TOKEN_1=AXXXXXXXXXXXXXXXXXXXXXXXXXXXX
RUNNER_TOKEN_2=AXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Runner names (must be unique across all machines)
RUNNER_NAME_1=runner-1
RUNNER_NAME_2=runner-2

# Labels applied to all runners
RUNNER_LABELS=self-hosted,linux,x64
